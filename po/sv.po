#: signbridge/app.py
msgid "Real-time sign language interpretation via camera"
msgstr "Realtids-teckenspråkstolkning via kamera"

#: signbridge/window.py
msgid "About SignBridge"
msgstr "Om SignBridge"

#: signbridge/window.py
msgid "Clear history"
msgstr "Rensa historik"

#: signbridge/window.py
msgid "Camera is not active. Press Start to begin."
msgstr "Kameran är inte aktiv. Tryck på Start för att börja."

#: signbridge/window.py
msgid "Camera preview will appear here"
msgstr "Kameraförhandsgranskning visas här"

#: signbridge/window.py
msgid "Detected Sign"
msgstr "Detekterat tecken"

#: signbridge/window.py
msgid "Current"
msgstr "Aktuellt"

#: signbridge/window.py
msgid "History"
msgstr "Historik"

#: signbridge/window.py
msgid "Start Camera"
msgstr "Starta kamera"

#: signbridge/window.py
msgid "Stop Camera"
msgstr "Stoppa kamera"

#: signbridge/window.py
msgid "Camera active — show signs to the camera"
msgstr "Kameran är aktiv — visa tecken mot kameran"

#: signbridge/window.py
msgid "Could not open camera. Check permissions."
msgstr "Kunde inte öppna kameran. Kontrollera behörigheter."

#: signbridge/window.py
msgid "Camera stopped."
msgstr "Kameran stoppad."
